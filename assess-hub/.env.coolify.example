# Required Coolify environment variables for assess-hub
# Set these in the Coolify UI under your service's Environment Variables section.

NEXTAUTH_URL=https://assess-hub.imoayad.me
NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>
DATABASE_URL=mysql://user:pass@host:port/db
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>

# ENABLE_DEV_AUTH is intentionally NOT set (defaults to false in production)
# GITHUB_ID and GITHUB_SECRET are optional
