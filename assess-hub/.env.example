# Local development — points at the MySQL container in docker-compose.dev.yml.
# Copy to .env (gitignored) and edit as needed: `cp .env.example .env`
#
# Both `npm run db:init` (which uses --env-file=.env) and Next.js will read this file.

DATABASE_URL=mysql://assesshub:assesshub@localhost:3306/assess_hub

# NextAuth
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=dev-secret-do-not-use-in-prod-replace-with-32+chars

# Enables the credentials provider for password-free local sign-in.
# MUST remain false (or unset) in production.
ENABLE_DEV_AUTH=true

# OAuth — leave blank for local dev (dev auth above is enough).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=
